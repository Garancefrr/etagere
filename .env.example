# =============================================
# ÉTAGÈRE — Variables d'environnement
# Copiez ce fichier en .env.local et remplissez
# =============================================

# --- Supabase ---
# Récupérer sur https://supabase.com → votre projet → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# --- Google OAuth ---
# Créer sur https://console.cloud.google.com → APIs → Credentials → OAuth 2.0
# Redirect URI à ajouter : https://xxxxxxxxxxxx.supabase.co/auth/v1/callback
# Et pour NextAuth : http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxxxxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxxxxxx

# --- NextAuth ---
# Générer avec: openssl rand -base64 32
NEXTAUTH_SECRET=votre-secret-aleatoire-32-chars
NEXTAUTH_URL=http://localhost:3000
